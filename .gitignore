data/
*.mat
*.npz
*.npy
*.h5
*.hdf5
*.csv
*.pkl
*.pickle
*.zip

# ── Model checkpoints ──────────────────────────────────────
*.ckpt
*.pt
*.pth
*.bin
*.safetensors
lightning_logs/
wandb/

# ── Python ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/
*.so
.venv/
venv/
env/

# ── MATLAB ─────────────────────────────────────────────────
*.asv
*.mex*
*.mlappinstall
*.mltbx
slprj/

# ── OS / IDE ───────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ── Jupyter ────────────────────────────────────────────────
.ipynb_checkpoints/
